{
  "manifest_version": 3,
  "name": "QBO DOM AI Extractor",
  "version": "1.0",

  "permissions": [],

  "host_permissions": [
    "https://qbo.intuit.com/*",
    "http://127.0.0.1:8080/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://qbo.intuit.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
